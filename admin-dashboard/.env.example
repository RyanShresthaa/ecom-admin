# Copy to .env for local development.

VITE_API_URL=/api

# Neon / Vercel Postgres — paste the pooled connection string from Vercel Storage.
# When set, the API persists to Postgres instead of server/data/store.json.
# Leave empty to keep using the local JSON file.
DATABASE_URL=

# Optional aliases (Vercel Storage sets these automatically):
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
