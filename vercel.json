{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build --prefix admin",
  "outputDirectory": "admin/dist",
  "installCommand": "npm install --prefix admin",
  "functions": {
    "api/proxy.js": { "maxDuration": 30 },
    "api/index.js": { "maxDuration": 30 },
    "api/[...path].js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/proxy?path=" },
    { "source": "/api/(.*)", "destination": "/api/proxy?path=$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
