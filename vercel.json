{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix admin-dashboard",
  "buildCommand": "npm run build --prefix admin-dashboard",
  "outputDirectory": "admin-dashboard/dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "admin-dashboard/server/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
