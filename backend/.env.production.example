# Production environment template (item 5) — copy to host secrets, never commit real values

NODE_ENV=production
PORT=5000
TRUST_PROXY_HOPS=1

DB_HOST=your-managed-postgres-host
DB_PORT=5432
DB_NAME=app
DB_USER=
DB_PASSWORD=

SECRET_KEY_ACCESS_TOKEN=
SECRET_KEY_REFRESH_TOKEN=

CLIENT_URL=https://shop.yourdomain.com
CORS_ORIGINS=https://shop.yourdomain.com
FRONTEND_URL=https://shop.yourdomain.com

ALLOW_MOCK_PAYMENT=false
EMAIL_USE_QUEUE=true

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

STRIPE_SECRET_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: fail startup if production checklist fails
# STRICT_PRODUCTION=true
