{
  "name": "@matina/api",
  "version": "1.0.0",
  "description": "Shared ecom API (customer + admin) — see docs/README.md, docs/ROUTE_MAP.md, /api/docs",
  "main": "server.js",
  "scripts": {
    "test": "node --test scripts/unit-security.test.mjs scripts/nepal-vat-math.test.mjs scripts/backend-db-flows.test.mjs",
    "test:api": "node --test scripts/api-smoke.test.mjs",
    "test:integration": "node --test scripts/integration-validation.test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\"",
    "email:worker": "node scripts/email-worker.mjs",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "db:migrate": "node scripts/migrate.mjs",
    "seed:staff": "node scripts/seed-verify-staff.mjs",
    "db:backup": "node scripts/backup-db.mjs",
    "check:smtp": "node scripts/check-smtp.mjs",
    "docs": "echo Open http://localhost:5000/api/docs after npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@sentry/node": "^10.53.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-slow-down": "^3.1.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
