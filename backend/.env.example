NODE_ENV=development
PORT=5000

# API docs (after npm run dev): http://localhost:5000/api/docs

# Option A — Neon / pooled URL (recommended; same DB for admin + customer)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Option B — local Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=e-commerce
DB_USER=postgres
DB_PASSWORD=your_db_password

# Use long random strings (32+ chars). Access and refresh MUST differ in production.
JWT_SECRET=
SECRET_KEY_ACCESS_TOKEN=
SECRET_KEY_REFRESH_TOKEN=

ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
ACCESS_TOKEN_MAX_AGE_MS=900000
REFRESH_TOKEN_MAX_AGE_MS=604800000

# Comma-separated allowed frontend origins (admin + customer + optional)
CLIENT_URL=http://localhost:5174
FRONTEND_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

PASSWORD_MIN_LENGTH=8

# Mobile app PIN length (digits only), both default 4–6
MOBILE_PIN_MIN=4
MOBILE_PIN_MAX=6

RATE_LIMIT_API=300
RATE_LIMIT_AUTH=30
RATE_LIMIT_PASSWORD=5
RATE_LIMIT_ADMIN=80
RATE_LIMIT_UPLOAD=40

GOOGLE_CLIENT_ID=
CLIENT_ID=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Queue outbound mail (run npm run email:worker in another process)
EMAIL_USE_QUEUE=false
EMAIL_WORKER_INTERVAL_MS=5000
EMAIL_WORKER_BATCH_SIZE=20

STRIPE_SECRET_KEY=
# In production, mock online pay is OFF unless you explicitly set:
ALLOW_MOCK_PAYMENT=false

RATE_LIMIT_VERIFY_EMAIL=20
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# # Optional: Google reCAPTCHA (enforced on register/login when set)
# RECAPTCHA_SECRET_KEY=
# RECAPTCHA_MIN_SCORE=0.5

# Optional: Sentry error monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Abuse / lockout
MAX_LOGIN_FAILURES=5
LOCKOUT_MINUTES=15
SLOW_DOWN_AFTER=80

LOG_FORMAT=json
LOG_LEVEL=info
