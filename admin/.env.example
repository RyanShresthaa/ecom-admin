# Browser calls this base (same-origin proxy in Next). Keep /api on Vercel.
NEXT_PUBLIC_API_URL=/api

# Server-side rewrite target for /api/* → your real Express API
# Local:
# BACKEND_URL=http://localhost:5000
# Vercel (required — not localhost):
# BACKEND_URL=https://your-api.example.com

# Optional Live Store override (defaults to NEXT_PUBLIC_API_URL or /api)
# NEXT_PUBLIC_SHARED_API_URL=/api
