# Shared ecom API (backend/) — required for admin dashboard
NEXT_PUBLIC_API_URL=/api

# Optional absolute URL if not using Next.js rewrites:
# NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional Live Store / shared API override (defaults to http://localhost:5000/api)
# NEXT_PUBLIC_SHARED_API_URL=http://localhost:5000/api

# Backend origin used by next.config.mjs rewrites in development
# BACKEND_URL=http://localhost:5000
