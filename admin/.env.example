# Shared ecom API (backend/) — required for admin dashboard
# Local Vite: keep /api (proxied to http://localhost:5000 in vite.config.js)
VITE_API_URL=/api

# Optional override for Live Store only (defaults to VITE_API_URL)
# VITE_SHARED_API_URL=/api

# Production (Vercel):
# 1. Keep VITE_API_URL=/api
# 2. Set BACKEND_URL to your deployed backend origin (NOT localhost), e.g.:
#      BACKEND_URL=https://your-api.example.com
# 3. Root Directory should be "admin" (or deploy from repo root — both include /api proxy)
# 4. Framework Preset: Vite (or Other) — not Next.js
# Do NOT set VITE_API_URL=http://localhost:5000

# Optional absolute URL if not using Vite/Vercel proxy:
# VITE_API_URL=https://your-api.example.com/api
